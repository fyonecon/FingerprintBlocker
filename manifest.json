{
  "manifest_version": 3,
  "name": "FingerprintBlocker",
  "version": "1.0.8",
  "description": "Block browser fingerprint. 拦截浏览器指纹。",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "./pages/popup/popup.html",
    "default_title": "FingerprintBlocker"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "./common/config.js", "./common/language.js", "./common/md5.js", "./common/func.js",
        "./content/dom_sync_data_bridge.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "./content/dom_block_fingerprint.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "./static/appicon-16.png",
    "32": "./static/appicon-32.png",
    "48": "./static/appicon-48.png",
    "128": "./static/appicon-128.png"
  },
  "minimum_chrome_version": "143.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "fingerprintblocker@datathink.top",
      "strict_min_version": "143.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}